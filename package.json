{
  "name": "propagent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "services/worker"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "migrate": "cd packages/db && npm run migrate",
    "seed": "cd packages/db && npm run seed",
    "auth-migrate": "cd packages/db && npx ts-node src/auth-migration.ts"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6"
  }
}
