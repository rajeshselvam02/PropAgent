# PropAgent Environment Variables

# Database
DATABASE_URL=postgresql://propagent:CHANGE_ME@localhost:5432/propagent
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_URL=redis://localhost:6379

# Security
MASTER_API_KEY=CHANGE_ME_TO_RANDOM_STRING
API_KEYS=key1,key2,key3
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
ENCRYPTION_KEY=32_BYTE_HEX_STRING

# WhatsApp Business API
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_API_KEY=your_api_key
WHATSAPP_PHONE_NUMBER=+91-XXXXX-XXXXX

# Meta Ads
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret

# Storage (for call recordings)
ALLOWED_STORAGE_DOMAINS=s3.amazonaws.com,storage.googleapis.com

# Service Ports
GATEWAY_PORT=4000
WHATSAPP_PORT=4001
COMMUTE_PORT=4002
ANALYTICS_PORT=4003

# Production
NODE_ENV=production
LOG_LEVEL=info
